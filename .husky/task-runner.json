{
   "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
   "tasks": [
      {
         "name": "dotnet-format-verify",
         "group": "pre-commit",
         "command": "dotnet",
         "args": ["format", "ObsidianDocsMcp/ObsidianDocsMcp.csproj", "--verify-no-changes", "--include", "${staged}"],
         "include": ["**/*.cs"]
      }
   ]
}
